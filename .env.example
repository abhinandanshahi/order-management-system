APP_NAME=Order Management System
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://oms:oms@db:5432/oms

BROKER_MIN_DELAY_SECONDS=0.2
BROKER_MAX_DELAY_SECONDS=0.8
BROKER_RANDOM_SEED=42

DAY_ORDER_EXPIRY_SECONDS=300
DAY_ORDER_SCAN_INTERVAL_SECONDS=1.0

MARKET_DATA_ENABLED=false
MARKET_DATA_URL=
MARKET_DATA_SYMBOLS=["RELIANCE","NIFTY"]
MARKET_DATA_RECONNECT_SECONDS=5
CORS_ORIGINS=["http://localhost:3000"]

